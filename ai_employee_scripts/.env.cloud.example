# Cloud Agent Environment Configuration
# Copy this file to .env.cloud and fill in the values
# DO NOT commit .env.cloud to version control

# ============================================================================
# REQUIRED: GLM (Zhipu AI) API Configuration
# ============================================================================
GLM=your_glm_api_key_here
GLM_BASE_URL=https://api.z.ai/v1/chat/completions
MODEL_NAME=glm-4.7-flash

# ============================================================================
# Vault Configuration
# ============================================================================
VAULT_PATH=./AI_Employee_Vault
AGENT_TYPE=cloud

# ============================================================================
# Agent Behavior
# ============================================================================
POLLING_INTERVAL=30
MAX_RETRIES=3
RETRY_DELAY=5

# ============================================================================
# Git Configuration
# ============================================================================
GIT_REMOTE=origin
GIT_AUTO_SYNC=true
GIT_SYNC_INTERVAL=300

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
# LOG_FILE=logs/cloud_agent.log

# ============================================================================
# OPTIONAL: OpenAI API (Alternative to Xiaomi)
# ============================================================================
# If you prefer to use OpenAI instead of Xiaomi, uncomment and configure:
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1/
# MODEL_NAME=gpt-4o-mini

# ============================================================================
# Cloud Watcher Credentials
# ============================================================================
# These credentials are used by cloud watchers (not local watchers)
# Local watchers continue to use credentials.json file

# Gmail OAuth Credentials (JSON format as single line)
# Get from Google Cloud Console: https://console.cloud.google.com/
# Create a Desktop app OAuth 2.0 client ID and download the JSON
# Copy the entire JSON content here (replace the example below)
GOOGLE_CREDENTIALS='{"installed":{"client_id":"your-client-id.apps.googleusercontent.com","project_id":"your-project-id","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_secret":"your-client-secret","redirect_uris":["http://localhost"]}}'

# LinkedIn API Credentials (for LinkedIn watcher)
# Note: LinkedIn API integration requires developer access
# For now, the LinkedIn watcher runs in mock mode without these
# LINKEDIN_CLIENT_ID=your_linkedin_client_id
# LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
# LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
