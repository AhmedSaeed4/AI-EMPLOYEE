# Gmail API
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here

# LinkedIn API (for posting)
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# LinkedIn Session (for messaging)
LINKEDIN_MCP_SESSION=/path/to/ai_employee_scripts/sessions/linkedin_mcp

# Odoo Accounting
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USER=your-odoo-user@example.com
ODOO_PASSWORD=your-odoo-password-here

# Meta (Facebook & Instagram)
META_ACCESS_TOKEN=your_meta_access_token_here
META_PAGE_ID=your_meta_page_id_here
INSTAGRAM_BUSINESS_ID=your_instagram_business_id_here

# Twitter/X
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here
